{
  "$schema": "https://raw.githubusercontent.com/vitodeploy/plugins/main/schema/manifest.schema.json",
  "name": "your-vendor/hello-world",
  "description": "A minimal starter VitoDeploy plugin. Copy this into plugins/ and rename it.",
  "version": "1.0.0",
  "license": "MIT",
  "type": "vito-plugin",
  "autoload": {
    "psr-4": {
      "App\\Vito\\Plugins\\YourVendor\\HelloWorld\\": ""
    }
  },
  "extra": {
    "vito": {
      "name": "Hello World",
      "categories": ["example"],
      "homepage": "https://vitodeploy.com/docs/plugins",
      "repository": "https://github.com/your-vendor/your-repo",
      "author": { "name": "Your Name", "github": "your-handle" },
      "official": false,
      "min_vito_version": "3.0.0",
      "icon": "assets/icon.svg"
    }
  }
}
